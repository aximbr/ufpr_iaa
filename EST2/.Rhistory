x <- as.matrix(train1[,2:ncol(train1)])
ncol(train1)
View(x)
test1 <- test1 %>% select(lwage, everything()) # teste1 é a base de teste padronizada
View(test1)
x_test = as.matrix(test1[,2:ncol(test1)]) # test1 é a base de teste padronizada
